<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<IncludeSymbols>true</IncludeSymbols>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>
		<PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
		<Authors>Peter Waher</Authors>
		<Company>Waher Data AB</Company>
		<Product>Waher.IoTGateway</Product>
		<Description>Publishes nodes representing external nodes using HTTP to communicate with the gateway.</Description>
		<Copyright>Copyright © Waher Data AB 2026. All rights reserved.</Copyright>
		<PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
		<PackageProjectUrl>https://github.com/PeterWaher/IoTGateway/tree/master/Things/Waher.Things.Http</PackageProjectUrl>
		<PackageIcon>Icon_64x64.png</PackageIcon>
		<PackageIconUrl />
		<RepositoryUrl>https://github.com/PeterWaher/IoTGateway</RepositoryUrl>
		<RepositoryType>GitHub</RepositoryType>
		<PackageTags>IoT HTTP REST</PackageTags>
		<NeutralLanguage>Enligsh</NeutralLanguage>
		<AssemblyVersion>1.0.0</AssemblyVersion>
		<FileVersion>1.0.0</FileVersion>
		<Version>1.0.0</Version>
	</PropertyGroup>
	<PropertyGroup>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
	</PropertyGroup>
	<ItemGroup>
	  <None Remove="Data\ApiDocumentation.md" />
	</ItemGroup>
	<ItemGroup>
	  <Content Include="Language\Waher.Things.Http.en.lng">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>
	<ItemGroup>
	  <EmbeddedResource Include="Data\ApiDocumentation.md">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<None Include="..\..\Images\Icon_64x64.png">
			<Pack>True</Pack>
			<PackagePath></PackagePath>
		</None>
		<None Include="..\..\LICENSE.txt">
			<Pack>True</Pack>
			<PackagePath></PackagePath>
		</None>
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\..\Content\Waher.Content.Markdown\Waher.Content.Markdown.csproj" />
	  <ProjectReference Include="..\..\Content\Waher.Content\Waher.Content.csproj" />
	  <ProjectReference Include="..\..\Networking\Waher.Networking.HTTP\Waher.Networking.HTTP.csproj" />
	  <ProjectReference Include="..\..\Networking\Waher.Networking\Waher.Networking.csproj" />
	  <ProjectReference Include="..\..\Runtime\Waher.Runtime.Inventory\Waher.Runtime.Inventory.csproj" />
	  <ProjectReference Include="..\..\Runtime\Waher.Runtime.Timing\Waher.Runtime.Timing.csproj" />
	  <ProjectReference Include="..\..\Security\Waher.Security.JWT\Waher.Security.JWT.csproj" />
	  <ProjectReference Include="..\..\Security\Waher.Security.Users\Waher.Security.Users.csproj" />
	  <ProjectReference Include="..\..\Security\Waher.Security\Waher.Security.csproj" />
	  <ProjectReference Include="..\Waher.Things.Metering\Waher.Things.Metering.csproj" />
	  <ProjectReference Include="..\Waher.Things\Waher.Things.csproj" />
	</ItemGroup>

</Project>
